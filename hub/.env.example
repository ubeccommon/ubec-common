# .env.example — hub
# Copy to .env and fill in values. Never commit .env to git.
# See UBEC_Server_Technical_Specifications.md §16 for full reference.

# ── Service identity ──────────────────────
SERVICE_NAME=ubec-hub
SERVICE_ENV=development         # production | staging | development
LOG_LEVEL=WARNING

# ── Database (PostgreSQL 16) ──────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ubec_hub
DB_USER=ubec_hub_app
DB_PASSWORD=                    # REQUIRED — never commit a value

# ── Hub API ───────────────────────────────
HUB_API_URL=https://iot.ubec.network
HUB_API_KEY=                    # REQUIRED

# ── Stellar ───────────────────────────────
STELLAR_NETWORK=testnet         # public | testnet
STELLAR_HORIZON_URL=https://horizon.stellar.org

# ── SSO (Phase 2 — Keycloak) ──────────────
KEYCLOAK_URL=https://auth.ubec.network
KEYCLOAK_REALM=ubec-commons
KEYCLOAK_CLIENT_ID=ubec-hub
KEYCLOAK_CLIENT_SECRET=         # REQUIRED for confidential clients

# ── Security ──────────────────────────────
SECRET_KEY=                     # REQUIRED — 64 random bytes
ALLOWED_HOSTS=localhost,hub.ubec.network
CORS_ORIGINS=https://ubec.network,https://iot.ubec.network

# ── Analytics ─────────────────────────────
PLAUSIBLE_URL=https://analytics.ubec.network
